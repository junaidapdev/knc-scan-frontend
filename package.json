{
  "name": "kayan-frontend",
  "version": "0.1.0",
  "description": "Kayan Sweets V1 Frontend — React + Vite + TypeScript",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.tsx",
