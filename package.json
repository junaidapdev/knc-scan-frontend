    "@tanstack/react-table": "^8.21.3",
    "axios": "^1.7.2",
    "canvas-confetti": "^1.9.4",
    "date-fns": "^4.1.0",
    "i18next": "^23.12.2",
    "i18next-browser-languagedetector": "^8.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.72.1",
    "react-i18next": "^15.0.0",
    "react-router-dom": "^6.24.1",
    "recharts": "^3.8.1",
